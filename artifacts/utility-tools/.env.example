# Copy this file to .env.local and fill in the values only if you need to
# override the backend URL (e.g. pointing at an externally hosted API).
#
# By default the frontend calls the co-located api-server artifact via the
# same-origin "/api" path, routed by the shared Replit proxy — no env var
# needed in development or production.
# VITE_API_URL=/api
